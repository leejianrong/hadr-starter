# Generated reports — the morning routine rebuilds these; do not commit churn.
reports/
*.sitrep.html

# dashboard.html is the exception: it is the product, and it is committed.
!dashboard.html

# Between-run state — rebuilt from the feeds; not a source artifact.
*.sqlite3

# Secrets stay out of the repo and out of the agent's context.
.env
.env.*

# Language debris — extend for whichever toolchain you pick in CLAUDE.md.
__pycache__/
.venv/
node_modules/
.DS_Store
